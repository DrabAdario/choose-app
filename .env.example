# Supabase (https://supabase.com) — copy from Project Settings → API.
# Only these two belong in the web app. Never put the database password,
# service_role key, or postgresql:// connection string here (those are not used by Vite).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Local dev: omit or set to "/". CI sets this to "/<repo-name>/" for GitHub Pages.
# VITE_BASE_PATH=/
